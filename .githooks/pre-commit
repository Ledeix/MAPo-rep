#!/usr/bin/env bash
set -euo pipefail

limit_bytes=$((50 * 1024 * 1024))

large_files=()
while IFS= read -r file; do
  [[ -f "$file" ]] || continue
  size=$(stat -c%s "$file")
  if (( size > limit_bytes )); then
    large_files+=("$file")
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if (( ${#large_files[@]} > 0 )); then
  echo "Commit blocked: staged files larger than 50MB detected:" >&2
  for file in "${large_files[@]}"; do
    size=$(stat -c%s "$file")
    mb=$(awk "BEGIN {printf \"%.2f\", $size/1024/1024}")
    echo "  - $file (${mb} MB)" >&2
  done
  echo "Use Git LFS or remove these files from staging." >&2
  exit 1
fi
